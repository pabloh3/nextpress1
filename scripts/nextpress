#!/usr/bin/env bash
set -euo pipefail

readonly CLI_VERSION="nextpress standalone 0.1.0"
readonly DEFAULT_INSTALL_DIR="/opt/nextpress"
readonly DEFAULT_VERSION="latest"
readonly COMPOSE_FILE="docker-compose.prod.yml"
readonly RELEASE_CONFIG_FILE="nextpress.config.json"
readonly BACKUP_DIR="backups"
readonly DEFAULT_COMPOSE_SPEC_URL="https://raw.githubusercontent.com/pabloh3/nextpress1/main/docker-compose.prod.yml"
readonly SETUP_URL="http://nextpress.localhost"

INSTALL_DIR="${NEXTPRESS_INSTALL_DIR:-$DEFAULT_INSTALL_DIR}"
INSTALL_VERSION="$DEFAULT_VERSION"
UPGRADE_OVERRIDE="false"
UPGRADE_YES="false"
POSITIONALS=()

info() {
	printf '%s\n' "$*"
}

warn() {
	printf '%s\n' "Warning: $*" >&2
}

fail() {
	printf '%s\n' "Error: $*" >&2
	exit 1
}

command_exists() {
	command -v "$1" >/dev/null 2>&1
}

docker_accessible() {
	docker info >/dev/null 2>&1
}

sudo_docker_accessible() {
	command_exists sudo && sudo docker info >/dev/null 2>&1
}

print_help() {
	cat <<EOF
nextpress - self-host and manage a NextPress server

Install NextPress:
  curl -fsSL https://raw.githubusercontent.com/pabloh3/nextpress1/main/install.sh | bash

Options:
  -d, --install-dir <path>   Install location (default: $DEFAULT_INSTALL_DIR)
  --version <tag>            Install a specific NextPress version.

Commands:
  install                    Install and start NextPress.
  upgrade                    Upgrade NextPress to the latest available image.
  upgrade --latest           Explicitly upgrade to the latest image.
  upgrade --version <tag>    Upgrade to a specific NextPress version.
  upgrade --override         Reset incompatible database state after backup.
  upgrade --override --yes   Run override mode without a confirmation prompt.
  reload                     Reload the web router.
  restart                    Restart NextPress services.
  status                     Show service status.
  logs [service...]          Follow service logs.
  uninstall --yes            Stop services and remove this install.
  version, -v, --version     Print command version.

Examples:
  nextpress install
  nextpress install --version beta-v1.0.2
  nextpress install --install-dir "\$HOME/nextpress"
  nextpress upgrade
  nextpress upgrade --version beta-v1.0.2
  nextpress upgrade --override --yes
  nextpress logs
EOF
}

parse_global_args() {
	while [ "$#" -gt 0 ]; do
		case "$1" in
			-d|--install-dir)
				if [ "${2:-}" = "" ] || [[ "${2:-}" == -* ]]; then
					fail "Missing value for $1. Use $1 <path>."
				fi
				INSTALL_DIR="$2"
				shift 2
				;;
			*)
				POSITIONALS+=("$1")
				shift
				;;
		esac
	done
}

resolve_install_dir() {
	local raw="$1"
	local resolved

	raw="${raw%"${raw##*[![:space:]]}"}"
	raw="${raw#"${raw%%[![:space:]]*}"}"

	if [ "$raw" = "" ]; then
		fail "Refusing to use an empty install directory."
	fi

	case "$raw" in
		/*) resolved="$raw" ;;
		*) resolved="$(pwd)/$raw" ;;
	esac

	while [ "${#resolved}" -gt 1 ] && [[ "$resolved" == */ ]]; do
		resolved="${resolved%/}"
	done

	if [ "$resolved" = "/" ]; then
		fail "Refusing to use root as the install directory."
	fi

	INSTALL_DIR="$resolved"
}

assert_docker_available() {
	if docker_accessible && docker compose version >/dev/null 2>&1; then
		return
	fi

	if sudo_docker_accessible && sudo docker compose version >/dev/null 2>&1; then
		return
	fi

	fail "Docker Compose v2 not found. Install Docker Engine + Compose plugin, then run this command again."
}

assert_install_dir_exists() {
	if [ ! -d "$INSTALL_DIR" ]; then
		fail "Install directory not found: $INSTALL_DIR. Install first: nextpress install"
	fi
}

assert_install_dir_writable() {
	local caddy_dir="$INSTALL_DIR/caddy_config"
	local file

	if [ ! -w "$INSTALL_DIR" ]; then
		fail "Install directory is not writable: $INSTALL_DIR. Re-run with sudo or choose a writable --install-dir."
	fi

	for file in "$INSTALL_DIR/$COMPOSE_FILE" "$INSTALL_DIR/.env" "$caddy_dir/Caddyfile"; do
		if [ -e "$file" ] && [ ! -w "$file" ]; then
			fail "Install file is not writable: $file. Re-run with sudo or fix ownership."
		fi
	done

	if [ -d "$caddy_dir" ] && [ ! -w "$caddy_dir" ]; then
		fail "Caddy config directory is not writable: $caddy_dir. Re-run with sudo or fix ownership."
	fi
}

sanitize_version_tag() {
	local raw="$1"
	if [[ ! "$raw" =~ ^[a-zA-Z0-9._-]+$ ]]; then
		fail "Invalid --version tag. Use only letters, numbers, dots, underscores, and dashes."
	fi
}

parse_install_args() {
	INSTALL_VERSION="$DEFAULT_VERSION"

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--version|-V)
				if [ "${2:-}" = "" ] || [[ "${2:-}" == -* ]]; then
					fail "Missing value for $1. Use $1 <tag>."
				fi
				sanitize_version_tag "$2"
				INSTALL_VERSION="$2"
				shift 2
				;;
			-*)
				fail "Unknown install option: $1"
				;;
			*)
				fail "Unexpected install argument: $1"
				;;
		esac
	done
}

parse_upgrade_args() {
	INSTALL_VERSION="$DEFAULT_VERSION"
	UPGRADE_OVERRIDE="false"
	UPGRADE_YES="false"

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--latest)
				INSTALL_VERSION="$DEFAULT_VERSION"
				shift
				;;
			--version|-V)
				if [ "${2:-}" = "" ] || [[ "${2:-}" == -* ]]; then
					fail "Missing value for $1. Use $1 <tag>."
				fi
				sanitize_version_tag "$2"
				INSTALL_VERSION="$2"
				shift 2
				;;
			--override)
				UPGRADE_OVERRIDE="true"
				shift
				;;
			--yes|-y)
				UPGRADE_YES="true"
				shift
				;;
			-*)
				fail "Unknown upgrade option: $1"
				;;
			*)
				fail "Unexpected upgrade argument: $1"
				;;
		esac
	done
}

parse_uninstall_args() {
	local yes="false"

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--yes|-y)
				yes="true"
				shift
				;;
			*)
				fail "Unknown uninstall option: $1"
				;;
		esac
	done

	if [ "$yes" != "true" ]; then
		fail "Refusing to uninstall without --yes. This removes containers, named volumes, images, and the install directory."
	fi
}

validate_compose_file() {
	local file="$1"
	local source="$2"

	if [ ! -s "$file" ]; then
		fail "Empty compose file from $source."
	fi

	if grep -Eq '^[[:space:]]*build[[:space:]]*:' "$file"; then
		fail "$source contains a Compose build stanza. nextpress install is Hub-only and only uses published images."
	fi
}

resolve_compose_file() {
	local target="$1"
	local source

	if [ "${NEXTPRESS_COMPOSE_URL:-}" != "" ]; then
		source="NEXTPRESS_COMPOSE_URL"
		curl -fsSL "$NEXTPRESS_COMPOSE_URL" -o "$target" || fail "Could not fetch compose from NEXTPRESS_COMPOSE_URL."
		validate_compose_file "$target" "$source"
		info "Using compose from: $NEXTPRESS_COMPOSE_URL"
		return
	fi

	if [ -f "./$COMPOSE_FILE" ]; then
		source="$(pwd)/$COMPOSE_FILE"
		cp "./$COMPOSE_FILE" "$target"
		validate_compose_file "$target" "$source"
		info "Using compose from: $source"
		return
	fi

	source="$DEFAULT_COMPOSE_SPEC_URL"
	curl -fsSL "$DEFAULT_COMPOSE_SPEC_URL" -o "$target" || fail "Could not fetch compose from default URL."
	validate_compose_file "$target" "$source"
	info "Using compose from: $source"
}

generate_secret_hex() {
	openssl rand -hex 16
}

generate_secret_base64() {
	openssl rand -base64 32
}

write_or_update_env() {
	local version="$1"
	local env_path="$INSTALL_DIR/.env"
	local tmp_path

	if ! command_exists openssl; then
		fail "openssl is required to generate install secrets."
	fi

	if [ ! -f "$env_path" ]; then
		umask 077
		cat > "$env_path" <<EOF
POSTGRES_PASSWORD=$(generate_secret_hex)
SESSION_SECRET=$(generate_secret_base64)
NEXTPRESS_VERSION=$version
EOF
		info "Generated new .env with secrets."
		return
	fi

	tmp_path="$(mktemp)"
	if grep -q '^NEXTPRESS_VERSION=' "$env_path"; then
		awk -v version="$version" 'BEGIN{done=0} /^NEXTPRESS_VERSION=/{print "NEXTPRESS_VERSION=" version; done=1; next} {print} END{if(done==0) print "NEXTPRESS_VERSION=" version}' "$env_path" > "$tmp_path"
	else
		cat "$env_path" > "$tmp_path"
		printf '%s\n' "NEXTPRESS_VERSION=$version" >> "$tmp_path"
	fi
	cat "$tmp_path" > "$env_path"
	rm -f "$tmp_path"
	info "Updated NEXTPRESS_VERSION in existing .env."
}

load_install_env() {
	local env_path="$INSTALL_DIR/.env"

	if [ ! -f "$env_path" ]; then
		fail "Missing install environment file: $env_path"
	fi

	POSTGRES_PASSWORD="$(awk -F= '/^POSTGRES_PASSWORD=/{print substr($0, index($0, "=") + 1); exit}' "$env_path")"
	if [ "${POSTGRES_PASSWORD:-}" = "" ]; then
		fail "Missing POSTGRES_PASSWORD in $env_path"
	fi
}

write_initial_caddyfile() {
	local caddy_dir="$INSTALL_DIR/caddy_config"
	local caddy_file="$caddy_dir/Caddyfile"

	mkdir -p "$caddy_dir" || fail "Could not create Caddy config directory: $caddy_dir"
	if [ -f "$caddy_file" ]; then
		return
	fi

	cat > "$caddy_file" <<'EOF' || fail "Could not write initial Caddyfile: $caddy_file"
{
  admin 0.0.0.0:2019
  email info@nextpress.ai
}

# First-boot catch-all. Docker publishes this through http://nextpress.localhost.
:80 {
  reverse_proxy app:5000
}
EOF
}

try_chown_to_sudo_user() {
	if [ "${SUDO_USER:-}" = "" ] || [ "$SUDO_USER" = "root" ]; then
		return
	fi

	if id "$SUDO_USER" >/dev/null 2>&1; then
		chown -R "$SUDO_USER":"$SUDO_USER" "$INSTALL_DIR" || true
	fi
}

compose() {
	if docker_accessible && docker compose version >/dev/null 2>&1; then
		docker compose -f "$COMPOSE_FILE" "$@"
		return
	fi

	if sudo_docker_accessible; then
		sudo docker compose -f "$COMPOSE_FILE" "$@"
		return
	fi

	fail "Docker is not accessible. Install Docker or run with a user that can access Docker."
}

docker_cmd() {
	if docker_accessible; then
		docker "$@"
		return
	fi

	if sudo_docker_accessible; then
		sudo docker "$@"
		return
	fi

	fail "Docker is not accessible. Install Docker or run with a user that can access Docker."
}

app_image() {
	printf '%s\n' "husseinkizz/nextpress:${INSTALL_VERSION}"
}

read_json_value() {
	local file="$1"
	local key="$2"

	if [ ! -f "$file" ]; then
		return 1
	fi

	if [ -r "$file" ]; then
		awk -v key="$key" '
			$0 ~ "\"" key "\"" {
				sub(/^[^:]*:[[:space:]]*/, "")
				sub(/[[:space:]]*,?[[:space:]]*$/, "")
				gsub(/^"|"$/, "")
				print
				exit
			}
		' "$file"
		return
	fi

	if command_exists sudo; then
		sudo awk -v key="$key" '
			$0 ~ "\"" key "\"" {
				sub(/^[^:]*:[[:space:]]*/, "")
				sub(/[[:space:]]*,?[[:space:]]*$/, "")
				gsub(/^"|"$/, "")
				print
				exit
			}
		' "$file"
		return
	fi

	return 1
}

chmod_schema_config() {
	local file="$1"

	if chmod 0644 "$file" 2>/dev/null; then
		return
	fi

	if command_exists sudo; then
		sudo chmod 0644 "$file" || fail "Could not set readable permissions on $file."
		return
	fi

	fail "Could not set readable permissions on $file."
}

write_schema_config_file() {
	local target="$1"
	local tmp_path

	tmp_path="$(mktemp)"
	cat > "$tmp_path" <<'EOF' || fail "Could not prepare schema config: $target"
{
  "schemaVersion": "legacy",
  "previousSchemaVersion": "legacy",
  "schemaPath": "shared/schema.ts",
  "hasSchemaChanges": false
}
EOF

	if ! cp "$tmp_path" "$target" 2>/dev/null; then
		if command_exists sudo; then
			sudo cp "$tmp_path" "$target" || fail "Could not write schema config: $target"
		else
			fail "Could not write schema config: $target"
		fi
	fi
	rm -f "$tmp_path"
	chmod_schema_config "$target"
}

read_config_value() {
	local file="$1"
	local key="$2"
	local value

	value="$(read_json_value "$file" "$key" || true)"
	if [ "$value" = "" ]; then
		fail "Missing $key in $file."
	fi

	printf '%s\n' "$value"
}

copy_release_config_from_image() {
	local image="$1"
	local target="$2"
	local container_id

	container_id="$(docker_cmd create "$image" 2>/dev/null)" || fail "Could not inspect release config from image: $image"
	docker_cmd cp "$container_id:/app/$RELEASE_CONFIG_FILE" "$target" >/dev/null || {
		docker_cmd rm -f "$container_id" >/dev/null 2>&1 || true
		fail "Release image does not include $RELEASE_CONFIG_FILE: $image"
	}
	docker_cmd rm -f "$container_id" >/dev/null 2>&1 || true
}

write_legacy_installed_config() {
	local config_path="$INSTALL_DIR/$RELEASE_CONFIG_FILE"

	if [ -f "$config_path" ]; then
		return
	fi

	write_schema_config_file "$config_path"
}

copy_installed_config() {
	local source="$1"
	local target="$INSTALL_DIR/$RELEASE_CONFIG_FILE"

	if ! cp "$source" "$target" 2>/dev/null; then
		if command_exists sudo; then
			sudo cp "$source" "$target" || fail "Could not update installed schema config."
		else
			fail "Could not update installed schema config."
		fi
	fi
	chmod_schema_config "$target"
}

cleanup_target_config() {
	local config_path="${1:-}"
	if [ "$config_path" = "" ]; then
		return
	fi

	rm -f "$config_path" 2>/dev/null || true
}

create_db_backup() {
	local backup_dir="$INSTALL_DIR/$BACKUP_DIR"
	local backup_path
	local timestamp

	timestamp="$(date +%Y%m%d%H%M%S)"
	backup_path="$backup_dir/nextpress-db-$timestamp.sql"
	mkdir -p "$backup_dir" || fail "Could not create backup directory: $backup_dir"

	info "Creating database backup: $backup_path"
	if ! compose exec -T postgres pg_dump -U postgres nextpress > "$backup_path"; then
		rm -f "$backup_path"
		fail "Database backup failed; refusing to continue."
	fi

	info "Database backup created: $backup_path"
}

confirm_override() {
	if [ "$UPGRADE_YES" = "true" ]; then
		return
	fi

	if [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
		fail "Refusing override without an interactive terminal. Re-run with --override --yes if you accept data reset."
	fi

	local answer=""
	printf '%s' "Override may reset existing database state after backup. Continue? Type yes: " >/dev/tty
	IFS= read -r answer </dev/tty || fail "Could not read override confirmation."
	if [ "$answer" != "yes" ]; then
		fail "Override cancelled."
	fi
}

reset_database_volume() {
	local container_id
	local volume_name

	info "Resetting database volume for override upgrade..."

	container_id="$(compose ps -q postgres || true)"
	if [ "$container_id" != "" ]; then
		volume_name="$(docker_cmd inspect --format '{{range .Mounts}}{{if eq .Destination "/var/lib/postgresql/data"}}{{.Name}}{{end}}{{end}}' "$container_id")"
	fi

	compose down --remove-orphans

	if [ "${volume_name:-}" = "" ]; then
		fail "Could not determine database volume name for override reset."
	fi

	docker_cmd volume rm "$volume_name" >/dev/null 2>&1 || warn "Could not remove database volume: $volume_name. It may already be absent."
}

ensure_postgres_running() {
	info "Starting database service..."
	compose up -d postgres
	info "Waiting for database to become healthy..."
	compose exec -T postgres pg_isready -U postgres >/dev/null || sleep 3
	compose exec -T postgres pg_isready -U postgres >/dev/null || fail "Database did not become ready."
}

run_schema_migrations() {
	local image="${1:-$(app_image)}"

	info "Applying database migrations from $image..."
	compose run --rm --no-deps app pnpm drizzle-kit migrate
}

resolve_public_ip() {
	local public_ip
	local service_url

	if [ "${NEXTPRESS_PUBLIC_IP:-}" != "" ]; then
		printf '%s\n' "$NEXTPRESS_PUBLIC_IP"
		return
	fi

	if [ -r /dev/tty ] && [ -w /dev/tty ]; then
		public_ip="$(prompt_public_ip 2>/dev/null || true)"
		if [ "$public_ip" != "" ]; then
			printf '%s\n' "$public_ip"
		fi
		return
	fi

	for service_url in "https://api.ipify.org" "https://ifconfig.me/ip"; do
		public_ip="$(curl -fsS --max-time 3 "$service_url" 2>/dev/null | tr -d '[:space:]' || true)"
		if [ "$public_ip" != "" ]; then
			printf '%s\n' "$public_ip"
			return
		fi
	done
}

prompt_public_ip() {
	local access_answer=""
	local public_ip=""

	printf '%s' "Will you access this NextPress instance from another machine? [y/N]: " >/dev/tty
	IFS= read -r access_answer </dev/tty || return 1
	case "$access_answer" in
		y|Y|yes|YES|Yes) ;;
		*) return ;;
	esac

	printf '%s' "Enter the public IP or hostname for this server: " >/dev/tty
	IFS= read -r public_ip </dev/tty || return 1
	public_ip="$(printf '%s' "$public_ip" | awk '{$1=$1; print}')"
	if [ "$public_ip" = "" ]; then
		return
	fi

	printf '%s\n' "$public_ip"
}

resolve_private_ip() {
	local server_ip

	server_ip="$(hostname -I 2>/dev/null | awk '{print $1}')"
	if [ "$server_ip" = "" ]; then
		server_ip="$(ip route get 1.1.1.1 2>/dev/null | awk '{for (i = 1; i <= NF; i++) if ($i == "src") {print $(i + 1); exit}}')"
	fi

	if [ "$server_ip" != "" ]; then
		printf '%s\n' "$server_ip"
	fi
}

print_post_install_hints() {
	local private_ip
	local public_ip
	local version="$1"
	public_ip="$(resolve_public_ip)"
	private_ip="$(resolve_private_ip)"

	cat <<EOF

============================================
       Installation complete
============================================

NextPress $version is running (Docker Hub image + compose stack).

Open the setup wizard in your browser:
  Local:   $SETUP_URL
  Public:  http://${public_ip:-YOUR_SERVER_IP}
  Private: http://${private_ip:-PRIVATE_SERVER_IP}

Allow inbound TCP ports 80 and 443 in your server firewall.

Useful commands:
  nextpress status
  nextpress logs
  nextpress upgrade
  nextpress restart
  nextpress uninstall --yes
EOF
}

run_install() {
	parse_install_args "$@"
	local target_config

	assert_docker_available
	mkdir -p "$INSTALL_DIR" || fail "Could not create install directory: $INSTALL_DIR"
	assert_install_dir_writable

	info "Resolving docker-compose.prod.yml..."
	resolve_compose_file "$INSTALL_DIR/$COMPOSE_FILE"
	write_initial_caddyfile
	write_or_update_env "$INSTALL_VERSION"
	try_chown_to_sudo_user
	load_install_env

	info ""
	info "Pulling images from Docker Hub..."
	(cd "$INSTALL_DIR" && compose pull)

	info ""
	target_config="$(mktemp)"
	trap 'cleanup_target_config "$target_config"' RETURN
	(cd "$INSTALL_DIR" && copy_release_config_from_image "$(app_image)" "$target_config")
	(cd "$INSTALL_DIR" && ensure_postgres_running)
	(cd "$INSTALL_DIR" && run_schema_migrations "$(app_image)")
	copy_installed_config "$target_config"
	cleanup_target_config "$target_config"
	trap - RETURN

	info ""
	info "Starting services..."
	(cd "$INSTALL_DIR" && compose up -d)

	sleep 3
	print_post_install_hints "$INSTALL_VERSION"
}

run_upgrade() {
	parse_upgrade_args "$@"
	local current_config
	local current_schema_version
	local has_schema_changes
	local previous_schema_version
	local target_config
	local target_schema_version

	assert_install_dir_exists
	assert_docker_available
	load_install_env
	write_legacy_installed_config

	info "Upgrading stack in $INSTALL_DIR to $INSTALL_VERSION..."
	if [ "${NEXTPRESS_SKIP_IMAGE_PULL:-}" = "true" ]; then
		info "Skipping image pull because NEXTPRESS_SKIP_IMAGE_PULL=true."
	else
		info "Pulling image: $(app_image)"
		docker_cmd pull "$(app_image)"
	fi

	target_config="$(mktemp)"
	trap 'cleanup_target_config "$target_config"' RETURN
	(cd "$INSTALL_DIR" && copy_release_config_from_image "$(app_image)" "$target_config")
	current_config="$INSTALL_DIR/$RELEASE_CONFIG_FILE"
	current_schema_version="$(read_config_value "$current_config" "schemaVersion")"
	target_schema_version="$(read_config_value "$target_config" "schemaVersion")"
	previous_schema_version="$(read_config_value "$target_config" "previousSchemaVersion")"
	has_schema_changes="$(read_config_value "$target_config" "hasSchemaChanges")"

	if [ "$current_schema_version" = "$target_schema_version" ]; then
		info "Schema is already at $target_schema_version."
		write_or_update_env "$INSTALL_VERSION"
		copy_installed_config "$target_config"
		cleanup_target_config "$target_config"
		trap - RETURN
		(cd "$INSTALL_DIR" && compose up -d)
		info "Upgrade complete. Schema is now $target_schema_version."
		return
	fi

	if [ "$has_schema_changes" = "true" ] && [ "$current_schema_version" != "$previous_schema_version" ]; then
		if [ "$UPGRADE_OVERRIDE" != "true" ]; then
			rm -f "$target_config"
			trap - RETURN
			fail "Schema upgrade expects $previous_schema_version but this install is on $current_schema_version. Upgrade through the required intermediate version, or rerun with --override if you accept database reset."
		fi
		(cd "$INSTALL_DIR" && ensure_postgres_running)
		(cd "$INSTALL_DIR" && create_db_backup)
		confirm_override
		(cd "$INSTALL_DIR" && reset_database_volume)
		write_or_update_env "$INSTALL_VERSION"
		load_install_env
		(cd "$INSTALL_DIR" && ensure_postgres_running)
		(cd "$INSTALL_DIR" && run_schema_migrations "$(app_image)")
		copy_installed_config "$target_config"
		cleanup_target_config "$target_config"
		trap - RETURN
		(cd "$INSTALL_DIR" && compose up -d)
		info "Override upgrade complete. Schema is now $target_schema_version."
		return
	fi

	if [ "$has_schema_changes" = "true" ]; then
		(cd "$INSTALL_DIR" && ensure_postgres_running)
		(cd "$INSTALL_DIR" && create_db_backup)
		write_or_update_env "$INSTALL_VERSION"
		load_install_env
		(cd "$INSTALL_DIR" && run_schema_migrations "$(app_image)")
	else
		info "No schema changes declared for this release."
		write_or_update_env "$INSTALL_VERSION"
		load_install_env
	fi

	copy_installed_config "$target_config"
	cleanup_target_config "$target_config"
	trap - RETURN
	(cd "$INSTALL_DIR" && compose up -d)
	info "Upgrade complete. Schema is now $target_schema_version."
}

run_reload() {
	assert_install_dir_exists

	info "Reloading Caddy in $INSTALL_DIR..."
	(cd "$INSTALL_DIR" && compose restart caddy)
}

run_restart() {
	assert_install_dir_exists

	info "Restarting all services in $INSTALL_DIR..."
	(cd "$INSTALL_DIR" && compose restart)
}

run_status() {
	assert_install_dir_exists
	(cd "$INSTALL_DIR" && compose ps)
}

run_logs() {
	assert_install_dir_exists
	(cd "$INSTALL_DIR" && compose logs -f "$@")
}

run_uninstall() {
	local image_id
	local image_ids

	parse_uninstall_args "$@"
	assert_install_dir_exists

	if [ -f "$INSTALL_DIR/$COMPOSE_FILE" ]; then
		info "Stopping stack and removing named volumes..."
		(cd "$INSTALL_DIR" && compose down -v --remove-orphans) || warn "Compose down failed; continuing cleanup."
	else
		warn "No $COMPOSE_FILE found; skipping compose down."
	fi

	info "Removing NextPress images (best effort)..."
	image_ids="$(docker_cmd images -q husseinkizz/nextpress || true)"
	for image_id in $image_ids; do
		docker_cmd rmi -f "$image_id" >/dev/null 2>&1 || true
	done

	info "Removing install directory: $INSTALL_DIR"
	if ! rm -rf "$INSTALL_DIR" 2>/dev/null; then
		if command_exists sudo; then
			sudo rm -rf "$INSTALL_DIR"
		else
			fail "Could not remove install directory: $INSTALL_DIR. Re-run with sudo or remove it manually."
		fi
	fi

	if [ -d "$INSTALL_DIR" ]; then
		fail "Could not remove install directory: $INSTALL_DIR. Re-run with sudo or remove it manually."
	fi

	info ""
	info "Uninstall finished."
}

main() {
	parse_global_args "$@"
	resolve_install_dir "$INSTALL_DIR"

	local command="${POSITIONALS[0]:-help}"
	local sub_args=("${POSITIONALS[@]:1}")

	case "$command" in
		help|--help|-h)
			print_help
			;;
		version|--version|-v)
			printf '%s\n' "$CLI_VERSION"
			;;
		install)
			run_install "${sub_args[@]}"
			;;
		upgrade)
			run_upgrade "${sub_args[@]}"
			;;
		reload)
			run_reload
			;;
		restart)
			run_restart
			;;
		status)
			run_status
			;;
		logs)
			run_logs "${sub_args[@]}"
			;;
		uninstall)
			run_uninstall "${sub_args[@]}"
			;;
		*)
			printf '%s\n\n' "Unknown command: $command" >&2
			print_help
			exit 1
			;;
	esac
}

main "$@"
